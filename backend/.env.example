# Required: Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# Local SQLite (used by default for local dev without Docker)
DATABASE_URL="sqlite:///./sqlite.db"

# --- Uncomment below to use PostgreSQL locally instead ---
# DATABASE_URL="postgresql+psycopg2://vinentoai:vinentoai_secret@localhost:5432/vinentoai"

# JWT secret for signing auth tokens (change this to a strong random string!)
SECRET_KEY="change-me-to-a-strong-random-secret"
